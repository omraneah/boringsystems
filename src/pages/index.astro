---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const featuredWork = (await getCollection('case-files', ({ data }) => data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const highlightedPiece = (await getCollection('operating-playbooks', ({ data }) => data.highlight))[0] ?? null;
---

<Base title="Ahmed Omrane">
  <div class="hero">
    <div class="hero-content">
      <h1 class="hero-heading">Systems that scale.<br />Judgment that holds.</h1>
      <p class="hero-sub">Engineering leadership under constraint. Case files and frameworks from the inside.</p>
    </div>
    <div class="hero-visual">
      <img src="/flywheel-logo.svg" alt="" aria-hidden="true" class="hero-logo" />
    </div>
    <div class="hero-rule"></div>
  </div>

  {highlightedPiece && (
    <section class="section highlight-section">
      <div class="section-inner">
        <p class="label section-label">Highlights</p>
        <a href={`/operating-playbooks/${highlightedPiece.slug}`} class="highlight-card">
          <div class="highlight-meta">
            <span class="highlight-series">{highlightedPiece.data.series}</span>
          </div>
          <h2 class="highlight-title">{highlightedPiece.data.title}</h2>
          <p class="highlight-description">{highlightedPiece.data.description}</p>
          <span class="highlight-read accent">Read →</span>
        </a>
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-inner">
      <p class="label section-label">Selected Case Files</p>
      <div class="cards">
        {featuredWork.map(item => (
          <ArticleCard
            title={item.data.title}
            description={item.data.description}
            href={`/case-files/${item.slug}`}
          />
        ))}
      </div>
      <a href="/case-files" class="see-all">All case files →</a>
    </div>
  </section>

</Base>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-xl);
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    position: relative;
  }

  .hero-content {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--size-3xl));
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--text);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-visual {
    flex: 0 0 346px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 346px;
    height: auto;
    opacity: 0.85;
    display: block;
  }

  .hero-rule {
    position: absolute;
    bottom: 0;
    left: var(--space-lg);
    right: var(--space-lg);
    height: 1px;
    background: var(--accent);
    opacity: 0.4;
  }

  .highlight-section {
    padding-bottom: 0;
  }

  .highlight-card {
    display: block;
    border-left: 2px solid var(--accent);
    background: var(--bg-elevated);
    padding: var(--space-lg);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .highlight-card:hover {
    border-left-color: var(--text);
  }

  .highlight-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .highlight-series {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .highlight-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, var(--size-2xl));
    line-height: 1.2;
    color: var(--text);
    margin-bottom: var(--space-sm);
  }

  .highlight-description {
    font-size: var(--size-base);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: var(--space-md);
  }

  .highlight-read {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
  }

  .section {
    padding: var(--space-xl) 0;
  }

  .section-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .section-label {
    margin-bottom: var(--space-md);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .see-all {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
    transition: color 0.15s;
    margin-top: var(--space-sm);
  }

  .see-all:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      min-height: calc(100svh - 64px);
      padding: var(--space-lg) var(--space-md) var(--space-lg);
      gap: 0;
    }

    .hero-visual {
      flex: 0 0 auto;
      width: 100%;
      justify-content: center;
    }

    .hero-logo {
      width: 320px;
    }

    .hero-rule {
      left: var(--space-md);
      right: var(--space-md);
    }

    .section {
      padding: var(--space-lg) 0;
    }

    .section-inner {
      padding: 0 var(--space-md);
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
