---
import Article from '@/layouts/Article.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('archive-en');
  return entries.map(entry => ({
    // `entry.slug` includes any on-disk subfolders (e.g.
    // `operating-playbooks/series-1-foundations/s1-p0-how-we-run`).
    // Those folders are Ahmed's grouping play — never part of the URL.
    // URL slug = file basename only. See docs/constraints.md "Content".
    params: { slug: entry.slug.split('/').pop() },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Article
  title={entry.data.title}
  description={entry.data.description}
  series={entry.data.series}
  backHref="/en/archive"
  backLabel="Archive"
>
  <Content />
</Article>
