---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { articleMeta } from '../../../lib/article-meta';

// Chronological, newest first. See docs/adr-002-home-selection.md.
const entries = (await getCollection('work-en'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Work" description="Case studies from real engagements — the architecture decisions, migrations, and transformations that shipped under constraint.">
  <div class="page">
    <div class="page-inner">
      <header class="page-header">
        <p class="label">Work</p>
        <h1 class="page-title">Work</h1>
        <p class="page-description muted">
          Case studies from the inside. Real constraints, real decisions, and the architecture trade-offs that shipped. Not testimonials — the work itself.
        </p>
      </header>

      <div class="work-list">
        {entries.map(item => (
          <ArticleCard
            title={item.data.title}
            description={item.data.description}
            href={`/en/work/${item.slug.split('/').pop()}`}
            meta={articleMeta(item.body, item.data.date, 'en')}
          />
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    margin-bottom: var(--space-sm);
  }

  .page-description {
    font-family: var(--font-body);
    font-size: var(--size-base);
    max-width: 560px;
    line-height: 1.65;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .page-inner {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: var(--size-2xl);
    }
  }
</style>
