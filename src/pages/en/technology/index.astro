---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { articleMeta } from '../../../lib/article-meta';

const technologyWork = (await getCollection('technology-en'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Technology" description="Tech, stack, and tooling — SaaS primitives, AI-native stacks, and the patterns behind them.">
  <div class="page">
    <div class="page-inner">
      <header class="page-header">
        <p class="label">Technology</p>
        <h1 class="page-title">Technology</h1>
        <p class="page-description muted">
          Tech, stack, and tooling. SaaS primitives, AI-native stacks, and the patterns behind them — pieces that are closer to the metal than System Design, and more opinionated than the case files.
        </p>
      </header>

      {technologyWork.length > 0 ? (
        <div class="work-list">
          {technologyWork.map(item => (
            <ArticleCard
              title={item.data.title}
              description={item.data.description}
              href={`/en/technology/${item.slug}`}
              meta={articleMeta(item.body, item.data.date, 'en')}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state muted">Technology pieces coming soon.</p>
      )}
    </div>
  </div>
</Base>

<style>
  .page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    margin-bottom: var(--space-sm);
  }

  .page-description {
    font-family: var(--font-body);
    font-size: var(--size-base);
    max-width: 560px;
    line-height: 1.65;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .empty-state {
    font-family: var(--font-body);
    font-size: var(--size-base);
  }

  @media (max-width: 768px) {
    .page-inner {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: var(--size-2xl);
    }
  }
</style>
