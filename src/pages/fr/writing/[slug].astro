---
import Article from '@/layouts/Article.astro';
import { getCollection } from 'astro:content';
import { readTime, formatDate } from '@/lib/article-meta';

export async function getStaticPaths() {
  const entries = await getCollection('writing-fr');
  return entries.map(entry => ({
    // Subfolders under the collection root are grouping-only; URL slug is
    // the file basename only. See docs/constraints.md "Content".
    params: { slug: entry.slug.split('/').pop() },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Article
  title={entry.data.title}
  description={entry.data.description}
  backHref="/fr/writing"
  backLabel="Writing"
  date={formatDate(entry.data.date, 'fr') ?? undefined}
  isoDate={entry.data.date ? entry.data.date.toISOString() : undefined}
  readTime={readTime(entry.body, 'fr')}
  lang="fr"
>
  <Content />
</Article>
