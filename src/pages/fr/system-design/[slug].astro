---
import Article from '../../../layouts/Article.astro';
import { getCollection } from 'astro:content';
import { readTime, formatDate } from '../../../lib/article-meta';

export async function getStaticPaths() {
  const entries = await getCollection('system-design-fr');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Article
  title={entry.data.title}
  description={entry.data.description}
  backHref="/fr/system-design"
  backLabel="System Design"
  date={formatDate(entry.data.date, 'fr') ?? undefined}
  readTime={readTime(entry.body, 'fr')}
  lang="fr"
>
  <Content />
</Article>
