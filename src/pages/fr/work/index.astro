---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { articleMeta } from '../../../lib/article-meta';

const entries = (await getCollection('work-fr'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Work" description="Études de cas vues de l'intérieur — architecture, migrations, transformations shippées sous contrainte réelle." lang="fr">
  <div class="page">
    <div class="page-inner">
      <header class="page-header">
        <p class="label">Work</p>
        <h1 class="page-title">Work</h1>
        <p class="page-description muted">
          Études de cas vues de l'intérieur. Contraintes réelles, décisions réelles, trade-offs d'architecture qui ont shippé. Pas des témoignages — le travail lui-même.
        </p>
      </header>

      <div class="work-list">
        {entries.map(item => (
          <ArticleCard
            title={item.data.title}
            description={item.data.description}
            href={`/fr/work/${item.slug.split('/').pop()}`}
            meta={articleMeta(item.body, item.data.date, 'fr')}
          />
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    margin-bottom: var(--space-sm);
  }

  .page-description {
    font-family: var(--font-body);
    font-size: var(--size-base);
    max-width: 560px;
    line-height: 1.65;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .page-inner {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: var(--size-2xl);
    }
  }
</style>
