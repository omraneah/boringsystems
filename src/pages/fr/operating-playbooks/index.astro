---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allWriting = await getCollection('operating-playbooks-fr');

const grouped: Record<string, typeof allWriting> = {};
for (const item of allWriting) {
  const key = item.data.series ?? 'Autre';
  if (!grouped[key]) grouped[key] = [];
  grouped[key].push(item);
}

for (const key of Object.keys(grouped)) {
  grouped[key].sort((a, b) => (a.data.playbook ?? 0) - (b.data.playbook ?? 0));
}

const sortedSeries = Object.entries(grouped).sort(([, a], [, b]) => {
  const snA = a[0]?.data.seriesNum ?? 0;
  const snB = b[0]?.data.seriesNum ?? 0;
  return snB - snA;
});
---

<Base title="Guides opérationnels" description="Guides opérationnels pour le leadership technique sous contrainte." lang="fr">
  <div class="page">
    <div class="page-inner">
      <header class="page-header">
        <p class="label">Guides opérationnels</p>
        <h1 class="page-title">Guides opérationnels</h1>
        <p class="page-description muted">
          Cadres opérationnels distillés de la pratique contrainte-à-scale. Chaque guide est au niveau des principes, immédiatement applicable, et conçu pour les leaders techniques qui construisent des systèmes qui durent au-delà de leur présence.
        </p>
      </header>

      {sortedSeries.map(([seriesName, items]) => (
        <section class="series-group">
          <p class="label series-label">{seriesName}</p>
          <div class="writing-grid">
            {items.map(item => (
              <ArticleCard
                title={item.data.title}
                description={item.data.description}
                href={`/fr/operating-playbooks/${item.slug}`}
                meta={item.data.playbook !== undefined ? `Guide ${item.data.playbook}` : undefined}
                readLabel="Lire →"
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Base>

<style>
  .page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    margin-bottom: var(--space-sm);
  }

  .page-description {
    font-family: var(--font-body);
    font-size: var(--size-base);
    max-width: 560px;
    line-height: 1.65;
  }

  .series-group {
    margin-bottom: var(--space-xl);
  }

  .series-label {
    margin-bottom: var(--space-md);
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .page-inner {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: var(--size-2xl);
    }

    .writing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
