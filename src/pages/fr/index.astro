---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const writing = await getCollection('writing-fr');
const work = await getCollection('work-fr');
const building = await getCollection('building-fr');

const allArticles = [
  ...writing.map((e) => ({ entry: e, lane: 'writing' as const })),
  ...work.map((e) => ({ entry: e, lane: 'work' as const })),
  ...building.map((e) => ({ entry: e, lane: 'building' as const })),
];

const highlights = allArticles
  .filter(({ entry }) => entry.data.highlight)
  .sort((a, b) => (a.entry.data.order ?? 99) - (b.entry.data.order ?? 99))
  .slice(0, 3);

const laneLabelsFr: Record<'writing' | 'work' | 'building', string> = {
  'writing': 'Writing',
  'work': 'Work',
  'building': 'Building',
};
---

<Base title="Ahmed Omrane" description="Des systèmes qui scalent. Un jugement qui tient." lang="fr">
  <div class="hero">
    <div class="hero-content">
      <h1 class="hero-heading">Des systèmes qui scalent.<br />Un jugement qui tient.</h1>
      <p class="hero-sub">Le leadership technique sous contrainte. Études de cas et cadres de l'intérieur.</p>
    </div>
    <div class="hero-visual">
      <img src="/flywheel-logo.svg" alt="" aria-hidden="true" class="hero-logo" />
    </div>
  </div>

  {highlights.length > 0 && (
    <section class="section highlight-section">
      <div class="section-inner">
        <p class="label section-label">À la une</p>
        <div class="highlight-stack">
          {highlights.map(({ entry, lane }) => (
            <a href={`/fr/${lane}/${entry.slug.split('/').pop()}`} class="highlight-card">
              <span class="highlight-series">{laneLabelsFr[lane]}</span>
              <h2 class="highlight-title">{entry.data.title}</h2>
              <p class="highlight-description">{entry.data.description}</p>
              <span class="highlight-read accent">Lire →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section contact-section">
    <div class="section-inner">
      <p class="label section-label">Contact</p>
      <div class="contact-box">
        <p class="contact-cta">Intéressé par une collaboration ou vous avez un retour ? Contactez-moi.</p>
        <form id="contact-form" class="contact-form" novalidate>
        <div class="field">
          <label for="email" class="field-label">Votre email</label>
          <input id="email" name="email" type="email" class="field-input" placeholder="vous@exemple.com" required />
        </div>
        <div class="field">
          <label for="message" class="field-label">Message</label>
          <textarea id="message" name="message" class="field-input field-textarea" placeholder="Qu'avez-vous en tête ?" required rows="5"></textarea>
        </div>
        <div class="form-footer">
          <button type="submit" class="submit-btn">Envoyer le message</button>
          <p id="form-status" class="form-status" aria-live="polite"></p>
        </div>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    btn.disabled = true;
    btn.textContent = 'Envoi…';
    status.textContent = '';
    status.className = 'form-status';

    try {
      const res = await fetch('/api/v1/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, message }),
      });

      if (res.ok) {
        status.textContent = 'Message envoyé. Je vous répondrai bientôt.';
        status.classList.add('form-status--ok');
        form.reset();
      } else {
        status.textContent = 'Une erreur s\'est produite. Veuillez réessayer.';
        status.classList.add('form-status--err');
      }
    } catch {
      status.textContent = 'Envoi impossible. Vérifiez votre connexion.';
      status.classList.add('form-status--err');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer le message';
    }
  });
</script>

<style>
  .hero {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-xl);
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-md);
  }

  .hero-content {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--text);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-visual {
    flex: 0 0 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 280px;
    height: auto;
    opacity: 0.85;
    display: block;
  }

  :global([data-theme="light"]) .hero-logo {
    filter: invert(1);
  }

  .highlight-section {
    padding: var(--space-md) 0;
  }

  .highlight-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .highlight-card {
    display: block;
    border-left: 2px solid var(--accent);
    background: var(--bg-elevated);
    padding: var(--space-md);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .highlight-card:hover {
    background: var(--bg);
  }

  .highlight-card:hover .highlight-title {
    color: var(--accent);
  }

  .highlight-series {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }

  .highlight-title {
    font-family: var(--font-display);
    font-size: var(--size-lg);
    line-height: 1.3;
    color: var(--text);
    margin-bottom: 0.4rem;
    transition: color 0.15s;
  }

  .highlight-description {
    font-size: var(--size-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .highlight-read {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .section {
    padding: var(--space-lg) 0;
  }

  .section-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .section-label {
    margin-bottom: var(--space-md);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .contact-section {
  }

  .contact-box {
    border: 1px solid var(--accent-dim);
    background: var(--bg-elevated);
    padding: var(--space-lg);
  }

  .contact-cta {
    font-size: var(--size-base);
    color: var(--text);
    margin-bottom: var(--space-lg);
    line-height: 1.65;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }

  .field-input {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--accent-dim);
    padding: 0.6rem 0.75rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .field-input:focus {
    border-color: var(--accent);
  }

  .field-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .submit-btn {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--bg);
    background: var(--text);
    border: none;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--accent);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-status {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
  }

  .form-status--ok {
    color: var(--accent);
  }

  .form-status--err {
    color: #e05252;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      min-height: calc(100svh - 64px);
      padding: var(--space-lg) var(--space-md) var(--space-lg);
      gap: 0;
    }

    .hero-visual {
      flex: 0 0 auto;
      width: 100%;
      justify-content: center;
    }

    .hero-logo {
      width: 240px;
    }


    .section {
      padding: var(--space-lg) 0;
    }

    .section-inner {
      padding: 0 var(--space-md);
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
