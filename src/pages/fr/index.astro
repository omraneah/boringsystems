---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const featuredWork = (await getCollection('case-files-fr', ({ data }) => data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const highlightedPiece = (await getCollection('operating-playbooks-fr', ({ data }) => data.highlight))[0] ?? null;
const highlightedCaseFile = (await getCollection('case-files-fr', ({ data }) => data.highlight))[0] ?? null;
---

<Base title="Ahmed Omrane" description="Des systèmes qui scalent. Un jugement qui tient." lang="fr">
  <div class="hero">
    <div class="hero-content">
      <h1 class="hero-heading">Des systèmes qui scalent.<br />Un jugement qui tient.</h1>
      <p class="hero-sub">Le leadership technique sous contrainte. Études de cas et cadres de l'intérieur.</p>
    </div>
    <div class="hero-visual">
      <img src="/flywheel-logo.svg" alt="" aria-hidden="true" class="hero-logo" />
    </div>
    <div class="hero-rule"></div>
  </div>

  {(highlightedPiece || highlightedCaseFile) && (
    <section class="section highlight-section">
      <div class="section-inner">
        <p class="label section-label">À la une</p>
        <div class="highlight-grid">
          {highlightedPiece && (
            <a href={`/fr/operating-playbooks/${highlightedPiece.slug}`} class="highlight-card">
              <div class="highlight-meta">
                <span class="highlight-series">{highlightedPiece.data.series}</span>
              </div>
              <h2 class="highlight-title">{highlightedPiece.data.title}</h2>
              <p class="highlight-description">{highlightedPiece.data.description}</p>
              <span class="highlight-read accent">Lire →</span>
            </a>
          )}
          {highlightedCaseFile && (
            <a href={`/fr/case-files/${highlightedCaseFile.slug}`} class="highlight-card">
              <div class="highlight-meta">
                <span class="highlight-series">Étude de cas</span>
              </div>
              <h2 class="highlight-title">{highlightedCaseFile.data.title}</h2>
              <p class="highlight-description">{highlightedCaseFile.data.description}</p>
              <span class="highlight-read accent">Lire →</span>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-inner">
      <p class="label section-label">Études de cas sélectionnées</p>
      <div class="cards">
        {featuredWork.map(item => (
          <ArticleCard
            title={item.data.title}
            description={item.data.description}
            href={`/fr/case-files/${item.slug}`}
            readLabel="Lire →"
          />
        ))}
      </div>
      <a href="/fr/case-files" class="see-all">Toutes les études de cas →</a>
    </div>
  </section>

  <section class="section contact-section">
    <div class="section-inner">
      <p class="label section-label">Contact</p>
      <div class="contact-box">
        <p class="contact-cta">Intéressé par une collaboration ou vous avez un retour ? Contactez-moi.</p>
        <form id="contact-form" class="contact-form" novalidate>
        <div class="field">
          <label for="email" class="field-label">Votre email</label>
          <input id="email" name="email" type="email" class="field-input" placeholder="vous@exemple.com" required />
        </div>
        <div class="field">
          <label for="message" class="field-label">Message</label>
          <textarea id="message" name="message" class="field-input field-textarea" placeholder="Qu'avez-vous en tête ?" required rows="5"></textarea>
        </div>
        <div class="form-footer">
          <button type="submit" class="submit-btn">Envoyer le message</button>
          <p id="form-status" class="form-status" aria-live="polite"></p>
        </div>
        </form>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

    btn.disabled = true;
    btn.textContent = 'Envoi…';
    status.textContent = '';
    status.className = 'form-status';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, message }),
      });

      if (res.ok) {
        status.textContent = 'Message envoyé. Je vous répondrai bientôt.';
        status.classList.add('form-status--ok');
        form.reset();
      } else {
        status.textContent = 'Une erreur s\'est produite. Veuillez réessayer.';
        status.classList.add('form-status--err');
      }
    } catch {
      status.textContent = 'Envoi impossible. Vérifiez votre connexion.';
      status.classList.add('form-status--err');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer le message';
    }
  });
</script>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--space-xl);
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    position: relative;
  }

  .hero-content {
    flex: 1 1 0;
    min-width: 0;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--size-3xl));
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: var(--text);
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .hero-visual {
    flex: 0 0 346px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 346px;
    height: auto;
    opacity: 0.85;
    display: block;
  }

  .hero-rule {
    position: absolute;
    bottom: 0;
    left: var(--space-lg);
    right: var(--space-lg);
    height: 1px;
    background: var(--accent);
    opacity: 0.4;
  }

  .highlight-section {
    padding-bottom: 0;
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .highlight-card {
    display: block;
    border-left: 2px solid var(--accent);
    background: var(--bg-elevated);
    padding: var(--space-lg);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .highlight-card:hover .highlight-title {
    color: var(--accent);
  }

  .highlight-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .highlight-series {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .highlight-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, var(--size-2xl));
    line-height: 1.2;
    color: var(--text);
    margin-bottom: var(--space-sm);
    transition: color 0.15s;
  }

  .highlight-description {
    font-size: var(--size-base);
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: var(--space-md);
  }

  .highlight-read {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
  }

  .section {
    padding: var(--space-xl) 0;
  }

  .section-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .section-label {
    margin-bottom: var(--space-md);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .see-all {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
    transition: color 0.15s;
    margin-top: var(--space-sm);
  }

  .see-all:hover {
    color: var(--accent);
  }

  .contact-section {
    border-top: 1px solid var(--border);
  }

  .contact-box {
    border: 1px solid var(--accent-dim);
    background: var(--bg-elevated);
    padding: var(--space-lg);
  }

  .contact-cta {
    font-size: var(--size-base);
    color: var(--text);
    margin-bottom: var(--space-lg);
    line-height: 1.65;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }

  .field-input {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--accent-dim);
    padding: 0.6rem 0.75rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .field-input:focus {
    border-color: var(--accent);
  }

  .field-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .submit-btn {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--bg);
    background: var(--text);
    border: none;
    padding: 0.6rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--accent);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-status {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
  }

  .form-status--ok {
    color: var(--accent);
  }

  .form-status--err {
    color: #e05252;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      min-height: calc(100svh - 64px);
      padding: var(--space-lg) var(--space-md) var(--space-lg);
      gap: 0;
    }

    .hero-visual {
      flex: 0 0 auto;
      width: 100%;
      justify-content: center;
    }

    .hero-logo {
      width: 320px;
    }

    .hero-rule {
      left: var(--space-md);
      right: var(--space-md);
    }

    .section {
      padding: var(--space-lg) 0;
    }

    .section-inner {
      padding: 0 var(--space-md);
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
