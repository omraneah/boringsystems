---
import Base from '../../../layouts/Base.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { articleMeta } from '../../../lib/article-meta';

const entries = (await getCollection('building-fr'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Building" description="Builds AI-native en cours — ce que je ship maintenant, avec les décisions documentées au fur et à mesure." lang="fr">
  <div class="page">
    <div class="page-inner">
      <header class="page-header">
        <p class="label">Building</p>
        <h1 class="page-title">Building</h1>
        <p class="page-description muted">
          Le travail en direct. Ce que je ship maintenant — AI-native, end-to-end, avec les décisions documentées au fur et à mesure. Pour les builders qui veulent voir le craft, pas seulement le produit fini.
        </p>
      </header>

      {entries.length > 0 ? (
        <div class="work-list">
          {entries.map(item => (
            <ArticleCard
              title={item.data.title}
              description={item.data.description}
              href={`/fr/building/${item.slug.split('/').pop()}`}
              meta={articleMeta(item.body, item.data.date, 'fr')}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state muted">Builds en direct bientôt.</p>
      )}
    </div>
  </div>
</Base>

<style>
  .page {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .page-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    margin-bottom: var(--space-sm);
  }

  .page-description {
    font-family: var(--font-body);
    font-size: var(--size-base);
    max-width: 560px;
    line-height: 1.65;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .empty-state {
    font-family: var(--font-body);
    font-size: var(--size-base);
  }

  @media (max-width: 768px) {
    .page-inner {
      padding: 0 var(--space-md);
    }

    .page-title {
      font-size: var(--size-2xl);
    }
  }
</style>
