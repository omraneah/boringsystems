---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleFeedback from '../components/ArticleFeedback.astro';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  series?: string;
  backHref: string;
  backLabel: string;
  lang?: 'en' | 'fr';
  date?: string;
  readTime?: string;
}

const { title, description, series, backHref, backLabel, lang = 'en', date, readTime } = Astro.props;
const showHeader = Boolean(date || readTime);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? title} />
    <link rel="canonical" href={canonicalUrl.href} />
    <title>{title} — Boring Systems</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('bs-theme');
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else if (!t && window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main class="article-main">
      <div class="article-container">
        <a href={backHref} class="back-link">← {backLabel}</a>

        {series && (
          <header class="article-header">
            <div class="article-meta">
              <span class="label">{series}</span>
            </div>
          </header>
        )}

        {showHeader && (
          <header class="article-intro">
            <h1 class="article-title">{title}</h1>
            {description && <p class="article-subtitle">{description}</p>}
            <p class="article-metaline">
              {date && <span>{date}</span>}
              {date && readTime && <span class="dot">·</span>}
              {readTime && <span>{readTime}</span>}
            </p>
          </header>
        )}

        <div class="article-body">
          <slot />
        </div>

        <ArticleFeedback articleTitle={title} articleUrl={canonicalUrl.href} />

        <div class="article-end">
          <a href={backHref} class="back-link">← {backLabel}</a>
        </div>
      </div>
    </main>
    <Footer />
    <Analytics />
    <SpeedInsights />
    <script>
      // Render mermaid code blocks if any are present on the page.
      // rehype-mermaid emits <pre class="mermaid"> blocks at build time.
      const nodes = document.querySelectorAll('pre.mermaid');
      if (nodes.length > 0) {
        const { default: mermaid } = await import('mermaid');
        const theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'default' : 'dark';
        mermaid.initialize({
          startOnLoad: false,
          theme,
          securityLevel: 'strict',
          fontFamily: 'var(--font-ui), system-ui, sans-serif',
        });
        await mermaid.run({ nodes });
      }
    </script>
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }

  /* Article body content styles */
  .article-body h1,
  .article-body h2,
  .article-body h3,
  .article-body h4 {
    font-family: var(--font-display);
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-body h1 { font-size: var(--size-2xl); }
  .article-body h2 { font-size: var(--size-xl); }
  .article-body h3 { font-size: var(--size-lg); }

  .article-body p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  .article-body ul,
  .article-body ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-body li {
    margin-bottom: 0.4rem;
    line-height: 1.65;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-lg) 0;
  }

  .article-body strong {
    color: var(--text);
    font-weight: 500;
  }

  .article-body a {
    color: var(--accent);
  }

  .article-body a:hover {
    color: var(--text);
  }

  .article-body blockquote {
    border-left: 2px solid var(--accent-dim);
    padding-left: var(--space-md);
    color: var(--text-muted);
    margin: var(--space-md) 0;
  }

  .article-body code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-elevated);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: var(--size-sm);
  }

  .article-body th,
  .article-body td {
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0.75rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.55;
  }

  .article-body th {
    font-family: var(--font-ui);
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--accent-dim);
  }

  .article-body pre.mermaid {
    background: var(--bg-elevated);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
    border-left: 2px solid var(--accent-dim);
    margin: var(--space-lg) 0;
    overflow-x: auto;
    min-height: 120px;
  }

  /* Before mermaid.js runs, show placeholder text instead of raw graph source. */
  .article-body pre.mermaid:not([data-processed="true"]) {
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    white-space: normal;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .article-body pre.mermaid:not([data-processed="true"])::before {
    content: "Rendering diagram…";
  }

  .article-body pre.mermaid:not([data-processed="true"]) > * {
    display: none;
  }

  .article-body pre.mermaid[data-processed="true"] svg {
    max-width: 100%;
    height: auto;
    display: inline-block;
  }
</style>

<style>
  .article-main {
    padding: var(--space-lg) var(--space-lg);
  }

  .article-container {
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .article-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
  }

  .article-intro {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-sm);
    color: var(--text);
  }

  .article-subtitle {
    font-family: var(--font-body);
    font-size: var(--size-base);
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .article-metaline {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .article-metaline .dot {
    opacity: 0.6;
  }

  .article-end {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .article-main {
      padding: var(--space-md);
    }
  }
</style>
