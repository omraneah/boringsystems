---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import ArticleFeedback from '@/components/ArticleFeedback.astro';
import '../styles/global.css';
import MixpanelAnalytics from '@/components/Analytics.astro';
import { hreflangsForPath } from '@/lib/i18n';
import { deriveLane } from '@/lib/lanes';

interface Props {
  title: string;
  description?: string;
  series?: string;
  backHref: string;
  backLabel: string;
  lang?: 'en' | 'fr';
  date?: string;
  isoDate?: string;
  lastModifiedIso?: string;
  readTime?: string;
  ogImage?: string;
  articleType?: 'BlogPosting' | 'Article';
}

const { title, description, series, backHref, backLabel, lang = 'en', date, isoDate, lastModifiedIso, readTime, ogImage = 'https://boringsystems.app/logo.png', articleType = 'BlogPosting' } = Astro.props;
const showHeader = Boolean(date || readTime);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const hreflangs = Astro.site ? hreflangsForPath(Astro.url.pathname, Astro.site) : null;
const metaDescription = description ?? title;
const pageTitle = `${title} — Boring Systems`;
const urlParts = Astro.url.pathname.split('/').filter(Boolean);
const lane = deriveLane(Astro.url.pathname);
const articleSlug = urlParts[urlParts.length - 1] ?? '';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': articleType,
  headline: title,
  description: metaDescription,
  inLanguage: lang === 'fr' ? 'fr-FR' : 'en-US',
  author: {
    '@type': 'Person',
    '@id': 'https://boringsystems.app/#ahmed-omrane',
    name: 'Ahmed Omrane',
    url: 'https://boringsystems.app',
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://boringsystems.app/#website',
    name: 'Boring Systems',
    url: 'https://boringsystems.app',
    logo: {
      '@type': 'ImageObject',
      url: 'https://boringsystems.app/logo.png',
    },
  },
  ...(isoDate ? { datePublished: isoDate } : {}),
  ...(lastModifiedIso
    ? { dateModified: lastModifiedIso }
    : isoDate
    ? { dateModified: isoDate }
    : {}),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl.href,
  },
  url: canonicalUrl.href,
  image: ogImage,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: lang === 'fr' ? 'Accueil' : 'Home',
      item: `https://boringsystems.app/${lang}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: backLabel,
      item: `https://boringsystems.app${backHref}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonicalUrl.href,
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Ahmed Omrane" />
    <link rel="canonical" href={canonicalUrl.href} />
    {hreflangs?.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Boring Systems" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
    {lang === 'en'
      ? <meta property="og:locale:alternate" content="fr_FR" />
      : <meta property="og:locale:alternate" content="en_US" />
    }
    {isoDate && <meta property="article:published_time" content={isoDate} />}
    <meta property="article:author" content="https://www.linkedin.com/in/omrane-ahmed/" />
    {backLabel && <meta property="article:section" content={backLabel} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Article + BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('bs-theme');
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else if (!t && window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body data-article-slug={articleSlug} data-lane={lane}>
    <Nav />
    <main class="article-main">
      <div class="article-container">
        <a href={backHref} class="back-link">← {backLabel}</a>

        {series && (
          <header class="article-header">
            <div class="article-meta">
              <span class="label">{series}</span>
            </div>
          </header>
        )}

        {showHeader && (
          <header class="article-intro">
            <h1 class="article-title">{title}</h1>
            {description && <p class="article-subtitle">{description}</p>}
            <p class="article-metaline">
              {date && <span>{date}</span>}
              {date && readTime && <span class="dot">·</span>}
              {readTime && <span>{readTime}</span>}
            </p>
          </header>
        )}

        <div class="article-body">
          <slot />
        </div>

        <ArticleFeedback articleTitle={title} articleUrl={canonicalUrl.href} />

        <div class="article-end">
          <a href={backHref} class="back-link">← {backLabel}</a>
        </div>
      </div>
    </main>
    <Footer />
    <MixpanelAnalytics />
    <script>
      // Render mermaid code blocks (if any) and wrap each one with a
      // zoom + pan controller so readers can explore the diagram.
      const nodes = document.querySelectorAll<HTMLElement>('pre.mermaid');
      if (nodes.length > 0) {
        const { default: mermaid } = await import('mermaid');
        const theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'default' : 'dark';
        mermaid.initialize({
          startOnLoad: false,
          theme,
          securityLevel: 'strict',
          fontFamily: 'var(--font-ui), system-ui, sans-serif',
        });
        await mermaid.run({ nodes });

        for (const pre of nodes) {
          const svg = pre.querySelector<SVGSVGElement>('svg');
          if (!svg) continue;

          // Strip mermaid's intrinsic sizing so we can drive width/height ourselves.
          svg.removeAttribute('width');
          svg.removeAttribute('height');
          svg.removeAttribute('style');

          const viewport = document.createElement('div');
          viewport.className = 'mermaid-viewport';
          const stage = document.createElement('div');
          stage.className = 'mermaid-stage';
          stage.appendChild(svg);
          viewport.appendChild(stage);

          const toolbar = document.createElement('div');
          toolbar.className = 'mermaid-toolbar';
          toolbar.innerHTML =
            '<button type="button" data-action="zoom-in" aria-label="Zoom in">+</button>' +
            '<button type="button" data-action="zoom-out" aria-label="Zoom out">−</button>' +
            '<button type="button" data-action="reset" aria-label="Reset view">↺</button>';

          pre.appendChild(viewport);
          pre.appendChild(toolbar);

          // Compute a base size that fits the viewport at scale=1, preserving
          // the SVG's aspect ratio (read from its viewBox). Scaling the SVG
          // via width/height keeps the vectors sharp at any zoom level.
          const vb = svg.viewBox && svg.viewBox.baseVal;
          const ratio = (vb && vb.width && vb.height) ? (vb.width / vb.height) : (16 / 9);

          let baseW = 0;
          let baseH = 0;

          function computeBase() {
            const r = viewport.getBoundingClientRect();
            const availW = Math.max(1, r.width - 16);
            const availH = Math.max(1, r.height - 16);
            if (availW / availH > ratio) {
              baseH = availH;
              baseW = availH * ratio;
            } else {
              baseW = availW;
              baseH = availW / ratio;
            }
          }

          let scale = 1;
          let tx = 0;
          let ty = 0;
          const MIN = 0.3;
          const MAX = 6;

          function apply() {
            stage.style.transform =
              'translate(-50%, -50%) translate(' + tx + 'px, ' + ty + 'px)';
            if (!svg) return;
            svg.style.width = (baseW * scale) + 'px';
            svg.style.height = (baseH * scale) + 'px';
          }

          function zoom(factor: number) {
            const next = Math.max(MIN, Math.min(MAX, scale * factor));
            if (next === scale) return;
            scale = next;
            apply();
          }

          computeBase();
          apply();

          const ro = new ResizeObserver(() => { computeBase(); apply(); });
          ro.observe(viewport);

          toolbar.addEventListener('click', (event) => {
            const target = event.target instanceof Element ? event.target.closest('button') : null;
            if (!target) return;
            const action = target.getAttribute('data-action');
            if (action === 'zoom-in') zoom(1.25);
            else if (action === 'zoom-out') zoom(1 / 1.25);
            else if (action === 'reset') { scale = 1; tx = 0; ty = 0; apply(); }
          });

          viewport.addEventListener('wheel', (event) => {
            event.preventDefault();
            zoom(event.deltaY < 0 ? 1.1 : 1 / 1.1);
          }, { passive: false });

          let dragging = false;
          let lastX = 0;
          let lastY = 0;

          viewport.addEventListener('pointerdown', (event) => {
            dragging = true;
            lastX = event.clientX;
            lastY = event.clientY;
            viewport.setPointerCapture(event.pointerId);
            viewport.classList.add('is-dragging');
          });

          viewport.addEventListener('pointermove', (event) => {
            if (!dragging) return;
            tx += event.clientX - lastX;
            ty += event.clientY - lastY;
            lastX = event.clientX;
            lastY = event.clientY;
            apply();
          });

          const stopDrag = (event: PointerEvent) => {
            if (!dragging) return;
            dragging = false;
            viewport.classList.remove('is-dragging');
            try { viewport.releasePointerCapture(event.pointerId); } catch {}
          };

          viewport.addEventListener('pointerup', stopDrag);
          viewport.addEventListener('pointercancel', stopDrag);
          viewport.addEventListener('pointerleave', stopDrag);
        }
      }
    </script>
    <script>
      import { trackScroll75 } from '@/lib/analytics';
      const slug = document.body.dataset.articleSlug ?? '';
      const articleLane = document.body.dataset.lane ?? 'unknown';
      let fired = false;
      const onScroll = () => {
        if (fired) return;
        if ((window.scrollY + window.innerHeight) / document.documentElement.scrollHeight >= 0.75) {
          fired = true;
          trackScroll75(slug, articleLane);
          window.removeEventListener('scroll', onScroll);
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }

  /* Article body content styles */
  .article-body h1,
  .article-body h2,
  .article-body h3,
  .article-body h4 {
    font-family: var(--font-display);
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-body h1 { font-size: var(--size-2xl); }
  .article-body h2 { font-size: var(--size-xl); }
  .article-body h3 { font-size: var(--size-lg); }

  .article-body p {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  .article-body ul,
  .article-body ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-body li {
    margin-bottom: 0.4rem;
    line-height: 1.65;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-lg) 0;
  }

  .article-body strong {
    color: var(--text);
    font-weight: 500;
  }

  .article-body a {
    color: var(--accent);
  }

  .article-body a:hover {
    color: var(--text);
  }

  .article-body blockquote {
    border-left: 2px solid var(--accent-dim);
    padding-left: var(--space-md);
    color: var(--text-muted);
    margin: var(--space-md) 0;
  }

  .article-body code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-elevated);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }

  .article-body pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0;
    font-size: var(--size-sm);
  }

  .article-body th,
  .article-body td {
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0.75rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.55;
  }

  .article-body th {
    font-family: var(--font-ui);
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--accent-dim);
  }

  /* Wide-table wrapper — lets a comparison table breach the prose column
     and use up to --max-wide horizontally, while still scrolling on mobile.
     Centered relative to the viewport (margin-left: 50% + translateX(-50%))
     so the table reads independently of the surrounding paragraph width. */
  .article-body .wide-table {
    position: relative;
    width: min(var(--max-wide), calc(100vw - 2 * var(--space-lg)));
    margin-left: 50%;
    transform: translateX(-50%);
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    overflow-x: auto;
  }

  .article-body .wide-table table {
    margin: 0;
    min-width: 720px;
  }

  .article-body .wide-table caption {
    caption-side: top;
    text-align: left;
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding-bottom: 0.5rem;
  }

  .article-body .wide-table th:first-child,
  .article-body .wide-table td:first-child {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .article-body .wide-table {
      width: calc(100vw - 2 * var(--space-md));
    }
  }

  .article-body pre.mermaid {
    position: relative;
    background: var(--bg-elevated);
    border-left: 2px solid var(--accent-dim);
    margin: var(--space-lg) 0;
    min-height: 160px;
    overflow: hidden;
  }

  /* Before mermaid.js runs, show placeholder text instead of raw graph source. */
  .article-body pre.mermaid:not([data-processed="true"]) {
    padding: var(--space-lg) var(--space-md);
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    white-space: normal;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .article-body pre.mermaid:not([data-processed="true"])::before {
    content: "Rendering diagram…";
  }

  .article-body pre.mermaid:not([data-processed="true"]) > * {
    display: none;
  }

  /* Rendered state — zoomable + pannable, moderate vertical footprint. */
  .article-body pre.mermaid[data-processed="true"] {
    padding: 0;
    min-height: 260px;
    height: 35vh;
    max-height: 360px;
  }

  .article-body .mermaid-viewport {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    cursor: grab;
    user-select: none;
    touch-action: none;
  }

  .article-body .mermaid-viewport.is-dragging {
    cursor: grabbing;
  }

  .article-body .mermaid-stage {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    will-change: transform;
  }

  .article-body .mermaid-stage svg {
    display: block;
    /* width + height are set inline by the zoom controller */
  }

  .article-body .mermaid-toolbar {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    display: flex;
    gap: 0.25rem;
    z-index: 2;
  }

  .article-body .mermaid-toolbar button {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    line-height: 1;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--accent-dim);
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    padding: 0;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .article-body .mermaid-toolbar button:hover {
    background: var(--bg-elevated);
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<style>
  .article-main {
    padding: var(--space-lg) var(--space-lg);
  }

  .article-container {
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .article-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    color: var(--text-muted);
  }

  .article-intro {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-sm);
    color: var(--text);
  }

  .article-subtitle {
    font-family: var(--font-body);
    font-size: var(--size-base);
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .article-metaline {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .article-metaline .dot {
    opacity: 0.6;
  }

  .article-end {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .article-main {
      padding: var(--space-md);
    }
  }
</style>
