---
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { hreflangsForPath } from '@/lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'fr';
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Engineering leadership case files and frameworks for the agentic AI era. Systems that scale. Judgment that holds.',
  lang = 'en',
  ogImage = 'https://boringsystems.app/logo.png',
  ogType = 'website',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const hreflangs = Astro.site ? hreflangsForPath(Astro.url.pathname, Astro.site) : null;
const pageTitle = title === 'Ahmed Omrane' ? 'Ahmed Omrane — Boring Systems' : `${title} — Boring Systems`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ahmed Omrane',
  url: 'https://boringsystems.app',
  description:
    'Engineering leader building at the seam of business model, product, and engineering. Case files and frameworks from 15 years in the field.',
  jobTitle: 'Engineering Leader',
  sameAs: [
    'https://www.linkedin.com/in/omrane-ahmed/',
    'https://medium.com/@ahmedomrane',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Boring Systems',
  url: 'https://boringsystems.app',
  description:
    'Engineering leadership case files and frameworks for the agentic AI era. Systems that scale. Judgment that holds.',
  publisher: {
    '@type': 'Person',
    name: 'Ahmed Omrane',
    url: 'https://boringsystems.app',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Ahmed Omrane" />
    <link rel="canonical" href={canonicalUrl.href} />
    {hreflangs?.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Boring Systems" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Person + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('bs-theme');
          if (t === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else if (!t && window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }
</style>
