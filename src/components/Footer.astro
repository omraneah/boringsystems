---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  lang?: 'en' | 'fr';
}

const { lang = 'en' } = Astro.props;

const t = lang === 'fr'
  ? {
      disclosure:
        "Une note sur la façon dont ce site est fait. Chaque partie — le codebase, les articles, le design, les éditions françaises — est construite et écrite par des agents AI sous mon orchestration, avec les principes documentés à travers les écrits. La langue source est l'anglais ; l'édition française est une traduction par AI calibrée pour l'accessibilité plutôt que pour la fidélité, donc quand les deux versions existent, lire l'anglais en premier.",
      work: 'Travailler avec moi',
    }
  : {
      disclosure:
        'A note on how this site is made. Every part of it — the codebase, the articles, the design, the French editions — is built and written by AI agents under my orchestration, using the principles documented across the writing. Source language is English; the French edition is an AI translation calibrated for accessibility rather than parity, so when both exist, read English first.',
      work: 'How we work together',
    };

const workWithMeHref = getRelativeLocaleUrl(lang, 'work-with-me/');
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="disclosure">{t.disclosure}</p>
    <div class="footer-row">
      <div class="links">
        <a href="https://www.linkedin.com/in/omrane-ahmed/" target="_blank" rel="noopener noreferrer">Ahmed Omrane — LinkedIn</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href={workWithMeHref}>{t.work}</a>
      </div>
      <div class="copyright">© 2026 Ahmed Omrane</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
    margin-top: var(--space-xl);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    color: var(--text-muted);
    line-height: 1.65;
  }

  .disclosure {
    margin: 0 0 var(--space-md);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .links a {
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .links a:hover {
    color: var(--accent);
  }

  .sep {
    opacity: 0.5;
  }

  .copyright {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .site-footer {
      padding: var(--space-md) var(--space-md) var(--space-lg);
    }
  }
</style>
