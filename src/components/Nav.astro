---
const pathname = Astro.url.pathname;
---

<nav class="site-nav">
  <ul class="nav-links">
    <li>
      <a href="/" class:list={[{ active: pathname === '/' }]}>Home</a>
    </li>
    <li><a href="/case-files" class:list={[{ active: pathname.startsWith('/case-files') }]}>Case Files</a></li>
    <li><a href="/operating-playbooks" class:list={[{ active: pathname.startsWith('/operating-playbooks') }]}><span class="label-full">Operating Playbooks</span><span class="label-short">Playbooks</span></a></li>
    <li><a href="/about" class:list={[{ active: pathname === '/about' }]}>About</a></li>
  </ul>
</nav>

<style>
  .site-nav {
    display: flex;
    justify-content: flex-end;
    padding: var(--space-md) var(--space-lg);
    max-width: var(--max-wide);
    margin: 0 auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .label-short {
    display: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }

@media (max-width: 768px) {
    .site-nav {
      padding: var(--space-sm) var(--space-md);
    }

    .nav-links {
      gap: var(--space-sm);
    }

    .label-full {
      display: none;
    }

    .label-short {
      display: inline;
    }
  }
</style>
