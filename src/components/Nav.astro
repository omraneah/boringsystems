---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { toLocalePath } from '@/lib/i18n';

const pathname = Astro.url.pathname;
const isFrench = pathname.startsWith('/fr');
const base = isFrench ? '/fr' : '/en';
const lang = isFrench ? 'fr' : 'en';

const isHome = pathname === `${base}` || pathname === `${base}/`;
const isWriting = pathname.startsWith(`${base}/writing`);
const isWork = pathname.startsWith(`${base}/work`);
const isBuilding = pathname.startsWith(`${base}/building`);
const isArchive = pathname.startsWith(`${base}/archive`);
const isAbout = pathname === `${base}/about` || pathname === `${base}/about/`;

// Lanes use identical slugs in both locales — `getRelativeLocaleUrl` is
// sufficient, no slug-alias table needed.
const homeHref = getRelativeLocaleUrl(lang, '');
const writingHref = getRelativeLocaleUrl(lang, 'writing');
const workHref = getRelativeLocaleUrl(lang, 'work');
const buildingHref = getRelativeLocaleUrl(lang, 'building');
const archiveHref = getRelativeLocaleUrl(lang, 'archive');
const aboutHref = getRelativeLocaleUrl(lang, 'about');

const langHref = toLocalePath(pathname, isFrench ? 'en' : 'fr');
---

<nav class="site-nav">
  <ul class="nav-links">
    <li>
      <a href={homeHref} class:list={[{ active: isHome }]}>
        {isFrench ? 'Accueil' : 'Home'}
      </a>
    </li>
    <li>
      <a href={writingHref} class:list={[{ active: isWriting }]}>
        Writing
      </a>
    </li>
    <li>
      <a href={workHref} class:list={[{ active: isWork }]}>
        Work
      </a>
    </li>
    <li>
      <a href={buildingHref} class:list={[{ active: isBuilding }]}>
        Building
      </a>
    </li>
    <li>
      <a href={archiveHref} class:list={[{ active: isArchive }]}>
        Archive
      </a>
    </li>
    <li>
      <a href={aboutHref} class:list={[{ active: isAbout }]}>
        {isFrench ? 'À propos' : 'About'}
      </a>
    </li>
  </ul>

  <div class="nav-controls">
    <a href={langHref} class="lang-toggle" title={isFrench ? 'Switch to English' : 'Passer en français'}>
      <span class:list={["opt", { active: !isFrench }]}>EN</span>
      <span class:list={["opt", { active: isFrench }]}>FR</span>
    </a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark mode" title="Toggle theme">
      <span class="icon-dark" aria-hidden="true">🌙</span>
      <span class="icon-light" aria-hidden="true">☀️</span>
    </button>
  </div>
</nav>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function applyTheme(theme) {
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
    }

    btn.addEventListener('click', function () {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'light' ? 'dark' : 'light';
      applyTheme(next);
      try { localStorage.setItem('bs-theme', next); } catch (e) {}
    });
  })();
</script>

<style>
  .site-nav {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    max-width: var(--max-wide);
    margin: 0 auto;
    gap: var(--space-md);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    justify-content: flex-end;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }

  /* Controls: language + theme */
  .nav-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: var(--space-sm);
    border-left: 1px solid var(--border);
    flex-shrink: 0;
  }

  .lang-toggle {
    display: flex;
    border: 1px solid var(--border);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .lang-toggle:hover {
    border-color: var(--accent-dim);
  }

  .lang-toggle .opt {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.45rem;
    color: var(--text-muted);
    line-height: 1;
    transition: color 0.15s, background-color 0.15s;
  }

  .lang-toggle .opt.active {
    background: var(--bg-elevated);
    color: var(--accent);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    background: none;
    border: 1px solid var(--border);
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .theme-toggle:hover {
    border-color: var(--accent-dim);
  }

  .icon-dark,
  .icon-light {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.2rem 0.45rem;
    font-size: var(--size-sm);
    line-height: 1;
    color: var(--text-muted);
    transition: color 0.15s, background-color 0.15s;
  }

  /* dark mode: moon active */
  .icon-dark { background: var(--bg-elevated); color: var(--text); filter: grayscale(1); }
  .icon-light { background: none; }

  /* light mode: sun active */
  [data-theme="light"] .icon-dark { background: none; color: var(--text-muted); }
  [data-theme="light"] .icon-light { background: var(--bg-elevated); color: var(--text); }

  @media (max-width: 768px) {
    .site-nav {
      padding: var(--space-sm) var(--space-md);
    }

    .nav-links {
      gap: var(--space-sm);
    }

    .nav-controls {
      gap: 0.4rem;
      padding-left: var(--space-sm);
    }
  }
</style>
