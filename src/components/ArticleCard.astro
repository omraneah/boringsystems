---
interface Props {
  title: string;
  description: string;
  href: string;
  meta?: string;
}

const { title, description, href, meta } = Astro.props;
---

<article class="article-card">
  <div class="card-inner">
    {meta && <p class="card-meta muted">{meta}</p>}
    <h3 class="card-title"><a href={href}>{title}</a></h3>
    <p class="card-excerpt muted">{description}</p>
    <a href={href} class="card-read accent">Read →</a>
  </div>
</article>

<style>
  .article-card {
    border-left: 2px solid var(--accent-dim);
    background: var(--bg-elevated);
    transition: border-color 0.15s;
  }

  .article-card:hover {
    border-left-color: var(--accent);
  }

  .card-inner {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-meta {
    font-family: var(--font-ui);
    font-size: var(--size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--size-lg);
    line-height: 1.3;
  }

  .card-title a {
    color: var(--text);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  .card-excerpt {
    font-size: var(--size-sm);
    line-height: 1.6;
  }

  .card-read {
    font-family: var(--font-ui);
    font-size: var(--size-sm);
    font-weight: 500;
    margin-top: 0.25rem;
    display: inline-block;
  }

  .card-read:hover {
    color: var(--text);
  }
</style>
