  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.5",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.17.1",
    "mermaid": "^11.14.0",
    "resend": "^6.11.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unist-util-visit": "^5.1.0"
  }
}
