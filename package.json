{
  "name": "boringsystems",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "verify": "tsx scripts/verify-structure.ts",
    "precommit": "astro check && npm run verify && astro build",
    "postinstall": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run precommit",
    "pre-push": "npm audit --audit-level=high"
  },
  "overrides": {
