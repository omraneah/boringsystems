# Required for /api/v1/contact, /api/v1/feedback, /api/v1/lead-magnet.
# Copy to .env.local (gitignored) and fill in real values.
# Production values live in the Vercel project environment.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives contact-form messages, feedback, and lead-magnet notifications.
CONTACT_TO_EMAIL=

# Verified sender address in Resend.
CONTACT_FROM_EMAIL=
